{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "rank": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "flags": { "type": "number" }
      },
      "required": ["uid", "name"]
    },
    "Session": {
      "title": "Session",
      "description": "Temporary session for QR login",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "approved", "expired"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Temporary QR login sessions"
    }
  }
}
